PORT=3001
NODE_ENV=development

# Required in production. Use a long random value.
JWT_SECRET=

# Required for Firebase ID token verification on /api/auth/sync.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Set to your deployed frontend origin, or a comma-separated list.
CORS_ORIGIN=http://localhost:5173

# Pick one AI provider.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
